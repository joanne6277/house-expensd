rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Household Ledger Validation
    function isValidHouseholdLedger(data) {
      return data.id is string && data.id.size() <= 100
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.monthlyBudget is number && data.monthlyBudget >= 0;
    }

    // Records (Bookkeeping entries) Validation
    function isValidBookkeepingRecord(data) {
      return data.id is string && data.id.size() <= 100
        && data.type is string && (data.type == 'income' || data.type == 'expense')
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.amount is number && data.amount >= 0
        && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.createdBy is string && data.createdBy == request.auth.uid
        && data.creatorName is string && data.creatorName.size() > 0 && data.creatorName.size() <= 100;
    }

    // Members Validation
    function isValidLedgerMember(data) {
      return data.userId is string && data.userId == request.auth.uid
        && data.nickname is string && data.nickname.size() > 0 && data.nickname.size() <= 100
        && data.color is string && data.color.size() <= 50;
    }

    // Matches for Path variables
    match /household_ledgers/{householdId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidHouseholdLedger(incoming()) && isValidId(householdId);
      allow update: if isSignedIn() && isValidHouseholdLedger(incoming()) && isValidId(householdId);
      allow delete: if false; // Ledgers can't be deleted via client normally

      match /records/{recordId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidBookkeepingRecord(incoming()) && isValidId(recordId);
        allow update: if isSignedIn() && isValidBookkeepingRecord(incoming()) && isValidId(recordId);
        allow delete: if isSignedIn() && existing().createdBy == request.auth.uid && isValidId(recordId);
      }

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidLedgerMember(incoming()) && isValidId(memberId);
        allow update: if isSignedIn() && isValidLedgerMember(incoming()) && isValidId(memberId);
        allow delete: if false;
      }
    }
  }
}
